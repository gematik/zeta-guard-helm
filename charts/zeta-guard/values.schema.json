{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "properties": {
    "authserver": {
      "type": "object",
      "properties": {
        "replicaCount": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of authserver (Keycloak) replicas."
        },
        "admin": {
          "type": "object",
          "properties": {
            "username": {
              "type": "string",
              "minLength": 1
            },
            "password": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "genesisHash": {
          "type": [
            "string",
            "null"
          ],
          "description": "Initial hash for admin events log (required for first install)"
        },
        "smcbHashingPepper": {
          "type": [
            "string",
            "null"
          ],
          "description": "Pepper value for SMCB hashing (required for first install)"
        },
        "image": {
          "$ref": "#/$defs/ZetaImage"
        },
        "hostname": {
          "type": "string",
          "description": "External hostname for the Keycloak authserver (passed as --hostname)."
        },
        "dbPool": {
          "type": "object",
          "properties": {
            "minSize": {
              "type": "integer",
              "minimum": 0,
              "description": "Keycloak --db-pool-min-size: minimum number of idle DB connections."
            },
            "maxSize": {
              "type": "integer",
              "minimum": 1,
              "description": "Keycloak --db-pool-max-size: maximum number of DB connections."
            }
          }
        },
        "httpPool": {
          "type": "object",
          "properties": {
            "maxThreads": {
              "type": "integer",
              "minimum": 1,
              "description": "Keycloak --http-pool-max-threads: maximum number of Undertow worker threads."
            }
          }
        },
        "imagePullSecrets": {
          "$ref": "#/$defs/K8sImagePullSecrets"
        },
        "provider": {
          "type": "object",
          "properties": {
            "smcB": {
              "type": "object",
              "properties": {
                "opa": {
                  "type": "object",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Enable OPA policy enforcement for SMC-B token exchange."
                    }
                  }
                },
                "opaBaseUrl": {
                  "type": "string",
                  "description": "Base URL of the active OPA instance (e.g. http://opa:8181)."
                },
                "opaSimulationBaseUrl": {
                  "type": "string",
                  "description": "Base URL of the OPA simulation instance. Set to empty string to disable shadow calls (e.g. http://opa-simulation:8181)."
                },
                "decisionPath": {
                  "type": "string",
                  "description": "OPA decision endpoint path (e.g. /v1/data/policies/zeta/authz/decision)."
                },
                "connectionTimeoutMs": {
                  "type": "integer",
                  "description": "HTTP connection timeout in milliseconds for OPA requests."
                },
                "readTimeoutMs": {
                  "type": "integer",
                  "description": "HTTP read timeout in milliseconds for OPA requests."
                },
                "failClosed": {
                  "type": "boolean",
                  "description": "When true, deny the token exchange if OPA is unreachable (503). When false, allow."
                }
              }
            }
          }
        }
      }
    },
    "authServerLogConsoleOutput": {
      "type": "string",
      "enum": [
        "default",
        "json"
      ]
    },
    "authServerMetricsEnabled": {
      "type": "boolean"
    },
    "authServerTracingEnabled": {
      "type": "boolean"
    },
    "gematik": {
      "type": "object",
      "properties": {
        "clientId": {
          "type": "string"
        },
        "serviceAccountEmailAddress": {
          "type": "string"
        },
        "workloadIdentityFederation": {
          "type": "object",
          "properties": {
            "projectNumber": {
              "type": "string"
            },
            "poolId": {
              "type": "string"
            },
            "workloadIdentityProvider": {
              "type": "string"
            }
          }
        }
      }
    },
    "gematikConnectionEnabled": {
      "type": "boolean"
    },
    "global": {
      "type": "object",
      "properties": {
        "imagePullSecrets": {
          "$ref": "#/$defs/K8sImagePullSecrets"
        },
        "registry_host": {
          "type": "string"
        }
      },
      "required": [
        "registry_host"
      ]
    },
    "opaDistributedTracingEnabled": {
      "type": "boolean"
    },
    "opaStatusPrometheus": {
      "type": "boolean"
    },
    "authserverDb": {
      "type": "object",
      "description": "Relevant only for cloudnativePg.enabled=false . This is how you can configure your own DB.",
      "properties": {
        "kcDb": {
          "type": "string",
          "description": "See environment variable KC_DB in keycloak config https://www.keycloak.org/server/db"
        },
        "kcDbUrl": {
          "type": "string",
          "description": "See environment variable KC_DB_URL in keycloak config https://www.keycloak.org/server/db"
        },
        "kcDbSecretName": {
          "type": "string",
          "description": "Name of a secret that contains the database username and password in its fields `username` and 'password'. Will be passed into environment variables KC_DB_USERNAME and KC_DB_PASSWORD. See keycloak config https://www.keycloak.org/server/db"
        },
        "kcDbSchema": {
          "type": "string",
          "description": "See environment variable KC_DB_SCHEMA in keycloak config https://www.keycloak.org/server/db"
        }
      }
    },
    "cloudnativePg": {
      "type": "object",
      "description": "Relevant only for cloudnativePg.enabled=true. Configures the managed CloudNativePG cluster.",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "instances": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of PostgreSQL instances in the CloudNativePG cluster. Use 1 for development/test only. Production deployments require >= 3 to avoid a single point of failure."
        },
        "imageName": {
          "type": "string",
          "description": "Container image for the CloudNativePG PostgreSQL cluster."
        },
        "resources": {
          "$ref": "#/$defs/K8sResourceRequirements"
        },
        "storage": {
          "type": "object",
          "properties": {
            "size": {
              "type": "string",
              "description": "Persistent volume size for the CloudNativePG cluster (for example: 10Gi)."
            }
          }
        }
      }
    },
    "pepproxy": {
      "type": "object",
      "properties": {
        "replicaCount": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of PEP proxy (Nginx) replicas."
        },
        "asl_enabled": {
          "type": "boolean"
        },
        "aslRootCA": {
          "type": "string",
          "minLength": 1
        },
        "aslOcspUrl": {
          "type": "string",
          "minLength": 1
        },
        "image": {
          "$ref": "#/$defs/ZetaImage"
        },
        "imagePullSecrets": {
          "$ref": "#/$defs/K8sImagePullSecrets"
        },
        "nginxConf": {
          "type": "object",
          "properties": {
            "configMapName": {
              "type": "string"
            },
            "fachdienstUrl": {
              "type": "string"
            },
            "fileContent": {
              "type": "string"
            },
            "generateConfigMap": {
              "type": "boolean"
            },
            "httpClientAcceptInvalidCerts": {
              "type": "boolean"
            },
            "aslTestmode": {
              "type": "boolean"
            },
            "locations": {
              "type": "string"
            },
            "pepIssuer": {
              "type": "string"
            },
            "poppIssuer": {
              "type": "string"
            },
            "requiredAudience": {
              "type": "string"
            },
            "requiredScopes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "configMapName",
            "generateConfigMap",
            "pepIssuer",
            "poppIssuer"
          ],
          "allOf": [
            {
              "if": {
                "properties": {
                  "generateConfigMap": {
                    "const": true
                  }
                }
              },
              "then": {
                "properties": {
                  "fachdienstUrl": {
                    "minLength": 1
                  },
                  "requiredAudience": {
                    "minLength": 1
                  }
                },
                "required": [
                  "fachdienstUrl",
                  "httpClientAcceptInvalidCerts",
                  "locations",
                  "pepIssuer",
                  "requiredAudience",
                  "requiredScopes"
                ]
              }
            }
          ]
        },
        "resources": {
          "$ref": "#/$defs/K8sResourceRequirements"
        },
        "sessionAffinity": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable ip-hash sticky sessions via NIC (hash $http_x_forwarded_for). Required when replicaCount > 1."
            }
          },
          "required": [
            "enabled"
          ]
        }
      },
      "required": [
        "nginxConf"
      ]
    },
    "pepproxyMetricsEnabled": {
      "type": "boolean"
    },
    "pepproxyTracingEnabled": {
      "type": "boolean"
    },
    "telemetry-gateway": {
      "type": "object"
    },
    "telemetryGatewayEnabled": {
      "type": "boolean"
    },
    "opa": {
      "type": "object",
      "properties": {
        "bundle": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "serviceName": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "resource": {
              "type": "string"
            },
            "polling": {
              "type": "object",
              "properties": {
                "min_delay_seconds": {
                  "type": "integer"
                },
                "max_delay_seconds": {
                  "type": "integer"
                }
              }
            },
            "verification": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "keyId": {
                  "type": "string"
                },
                "algorithm": {
                  "type": "string"
                },
                "publicKey": {
                  "type": "string"
                },
                "scope": {
                  "type": "string"
                }
              }
            },
            "credentials": {
              "type": "object",
              "properties": {
                "secretRef": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "replicaCount": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of OPA replicas."
        },
        "logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "description": "OPA server log level."
        },
        "image": {
          "type": "string"
        },
        "imagePullPolicy": {
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        },
        "imagePullSecrets": {
          "$ref": "#/$defs/K8sImagePullSecrets"
        },
        "resources": {
          "$ref": "#/$defs/K8sResourceRequirements"
        },
        "workloadIdentityFederation": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          }
        },
        "simulation": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "replicaCount": {
              "type": "integer",
              "minimum": 1
            },
            "bundle": {
              "type": "object",
              "properties": {
                "resource": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "workloadIdentityFederation": {
                "type": "object",
                "properties": {
                  "enabled": {
                    "const": true
                  }
                }
              }
            }
          },
          "then": {
            "not": {
              "properties": {
                "bundle": {
                  "type": "object",
                  "properties": {
                    "credentials": {
                      "type": "object",
                      "properties": {
                        "secretRef": {
                          "type": "object",
                          "properties": {
                            "name": {
                              "type": "string",
                              "minLength": 1
                            }
                          },
                          "required": [
                            "name"
                          ]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "bundle": {
                "type": "object",
                "properties": {
                  "enabled": {
                    "const": true
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "bundle": {
                "properties": {
                  "serviceName": {
                    "minLength": 1
                  },
                  "resource": {
                    "minLength": 1
                  }
                },
                "required": [
                  "serviceName",
                  "resource"
                ]
              }
            }
          }
        }
      ]
    },
    "ingressMasterAnnotations": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "ingressMinionAnnotations": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "routeViaTigerProxy": {
      "type": "boolean"
    },
    "ingressClassName": {
      "type": "string"
    },
    "clusterIssuer": {
      "type": "string"
    },
    "nginxIngressEnabled": {
      "type": "boolean"
    },
    "nginx-ingress": {
      "type": "object",
      "properties": {
        "controller": {
          "type": "object",
          "properties": {
            "ingressClass": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                }
              }
            },
            "config": {
              "type": "object",
              "properties": {
                "entries": {
                  "type": "object",
                  "properties": {
                    "ssl-protocols": {
                      "type": "string"
                    },
                    "ssl-ciphers": {
                      "type": "string"
                    },
                    "ssl-ciphersuites": {
                      "type": "string"
                    },
                    "ssl-ecdh-curve": {
                      "type": "string"
                    },
                    "ssl-session-cache": {
                      "type": "string"
                    },
                    "ssl-session-tickets": {
                      "type": "string"
                    },
                    "ssl-session-timeout": {
                      "type": "string"
                    },
                    "ssl-stapling": {
                      "type": "string"
                    },
                    "ssl-prefer-server-ciphers": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            },
            "enableCustomResources": {
              "type": "boolean"
            },
            "service": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "externalTrafficPolicy": {
                  "type": "string"
                },
                "httpPort": {
                  "type": "object"
                },
                "httpsPort": {
                  "type": "object"
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "devMode": {
      "type": "boolean"
    },
    "registry_name": {
      "type": "string"
    }
  },
  "required": [
    "authServerLogConsoleOutput",
    "authServerMetricsEnabled",
    "authServerTracingEnabled",
    "gematikConnectionEnabled",
    "global",
    "opaDistributedTracingEnabled",
    "opaStatusPrometheus",
    "pepproxy",
    "pepproxyMetricsEnabled",
    "pepproxyTracingEnabled",
    "telemetryGatewayEnabled"
  ],
  "title": "Values",
  "type": "object",
  "$defs": {
    "ZetaImage": {
      "type": "object",
      "properties": {
        "digest": {
          "type": "string",
          "pattern": "^[a-z0-9+._-]+:[a-zA-Z0-9=_-]+$"
        },
        "registry": {
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_][a-zA-Z0-9._-]{0,127}$"
        }
      }
    },
    "K8sImagePullSecrets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/K8sLocalObjectReference"
      }
    },
    "K8sLocalObjectReference": {
      "$comment": "Siehe https://kubernetes.io/docs/reference/kubernetes-api/common-definitions/local-object-reference/#LocalObjectReference",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "name"
      ]
    },
    "K8sResourceRequirements": {
      "$comment": "https://kubernetes.io/docs/reference/kubernetes-api/workload-resources/pod-v1/#resources",
      "type": "object",
      "description": "Compute Resources required by this container. ",
      "properties": {
        "limits": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "requests": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  }
}
